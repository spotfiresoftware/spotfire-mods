{
    "apiVersion": "$MOD-API-VERSION",
    "version": "1.0",
    "type": "action",
    "name": "$MOD-NAME",
    "id": "$MOD-ID",
    "description": "Description of what the mod does.",
    "capabilities": ["AI"],
    "icon": "icon.svg",
    "scripts": [
        {
            "id": "marking-insight",
            "name": "Result of the marking insight",
            "entryPoint": "markingInsight",
            "file": "build/marking-insight.js",
            "parameters": [
                {
                    "name": "insightInfo",
                    "type": "String"
                },
                {
                    "name": "dataTable",
                    "type": "DataTable"
                }
            ]
        }
    ],
    "agents": [
        {
            "id": "marking-agent",
            "name": "My marking agent",
            "type": "marking",
            "description": "Figures out insights about the marked data.",
            "entryPoint": "markingAgent",
            "file": "build/marking-agent.js"
        }
    ]
}
