{
    "compilerOptions": {
        "incremental": true,
        "target": "ES6",
        "module": "CommonJS",
        "rootDir": "src",
        "outDir": "dist",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "moduleResolution": "node",
        "strict": true
    },
    "include": ["src"],
    "exclude": ["templates"]
}